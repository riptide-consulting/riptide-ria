# Copy this file to .env and fill in real values. .env is gitignored -- never commit it.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model routing -- operator policy (root CLAUDE.md); do not upgrade without explicit approval.
# All four IDs are pinned snapshots. Since the Claude 4.6 generation, dateless IDs
# (claude-sonnet-5, claude-opus-4-8) ARE the snapshot, not evergreen aliases; the Haiku ID
# predates that scheme, hence its date suffix. See Anthropic's model versioning docs.
MODEL_CLASSIFIER=claude-haiku-4-5-20251001
MODEL_SPECIALIST=claude-sonnet-5
MODEL_EVALUATOR=claude-opus-4-8
MODEL_SYNTHESIZER=claude-sonnet-5

# Federal Register API -- free, public, no key required
FEDERAL_REGISTER_API_URL=https://www.federalregister.gov/api/v1
FEDERAL_REGISTER_AGENCIES=centers-for-medicare-medicaid-services,food-and-drug-administration

# Notion -- OPTIONAL: ingest/classify/analyze/evaluate all run without it. Needed only for
# the Evaluator's precedent lookups to return results and for --synthesize's gated write.
# (see mcp_servers/notion_tracker/verify_connection.py to confirm these are correct)
NOTION_API_KEY=ntn_your-integration-token-here
NOTION_DATABASE_ID=your-database-id-here
NOTION_DATA_SOURCE_ID=your-data-source-id-here

# Google OAuth (Phase 3: Drive + Gmail) -- path to the client credentials JSON downloaded
# from Google Cloud Console (OAuth 2.0 Client ID, Desktop app type). See scratchpad/scratchpad.md
# for the full setup walkthrough. Token files get written alongside this path automatically.
GOOGLE_CREDENTIALS_PATH=config/your-oauth-client-secret.json
GMAIL_ESCALATION_ADDRESS=escalations@yourcompany.com
GMAIL_SENDER_ADDRESS=you@yourcompany.com

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/ria.log

# Per-role output token caps
MAX_TOKENS_CLASSIFIER=1024
MAX_TOKENS_SPECIALIST=4096
MAX_TOKENS_EVALUATOR=2048
MAX_TOKENS_SYNTHESIZER=8192

# Autonomy tier thresholds live in config/pipeline_config.json's "autonomy" section
# (tier1_threshold, tier2_threshold, etc.), not here -- see agents/evaluator/CLAUDE.md.
