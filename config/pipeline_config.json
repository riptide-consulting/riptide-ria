{
  "pipeline": {
    "max_retries": 3,
    "cache_ttl_seconds": 3600,
    "batch_size": 10,
    "headless_mode": false
  },
  "federal_register": {
    "agencies": [
      "centers-for-medicare-medicaid-services",
      "food-and-drug-administration"
    ],
    "document_types": ["RULE", "PRORULE", "NOTICE"],
    "lookback_days": 7
  },
  "autonomy": {
    "tier1_threshold": 0.90,
    "tier2_threshold": 0.75,
    "tier3_threshold": 0.60,
    "critical_risk_always_escalates": true,
    "enforcement_language_always_escalates": true
  },
  "output": {
    "docx_template": "config/riptide_template.docx",
    "pptx_template": "config/riptide_template.pptx",
    "output_path_docx": "outputs/docx",
    "output_path_pptx": "outputs/pptx"
  }
}
