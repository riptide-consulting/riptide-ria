{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "python .claude/hooks/guard_secrets.py" }
        ]
      },
      {
        "matcher": "Bash|PowerShell|mcp__.*",
        "hooks": [
          { "type": "command", "command": "python .claude/hooks/guard_side_effects.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python .claude/hooks/audit_log.py", "async": true }
        ]
      }
    ]
  }
}
